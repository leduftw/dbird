{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dbird-leaderboard",
  "main": "src/index.js",
  "compatibility_date": "2026-07-19",
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "d1_databases": [
